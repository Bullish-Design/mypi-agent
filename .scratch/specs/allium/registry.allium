-- allium: 3

-- Registry: records what was installed.
-- R-015: Generated state must record meaningful source identity.

use "./core.allium" as core

entity InstallRegistry {
    package_name: String
    package_version: String
    installed_integrity: String
}

surface LocalRegistrySurface {
    facing _: InstallRegistry

    provides:
        SyncCompleted()
}

-- R-015: Record exact installed artifact identity

rule RecordInstalledPackage {
    when: SyncCompleted()
    requires: core/PiExecutable.installed
    ensures: InstallRegistry.package_name = core/PiPackage.name
    ensures: InstallRegistry.package_version = core/PiExecutable.installed_version
    ensures: InstallRegistry.installed_integrity = core/PiExecutable.installed_integrity_hash
    @guidance
        -- Record the exact package name, version, and integrity hash
        -- from the installed artifact in node_modules.
}

invariant RegistryRecordsExactInstall {
    core/PiExecutable.installed implies
        InstallRegistry.package_name != ""
        and InstallRegistry.package_version != ""
}
