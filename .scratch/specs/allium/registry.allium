-- allium: 3

-- Registry and install metadata specification.
-- R-015: Generated state must record meaningful source identity.

use "./core.allium" as core

entity PrimitiveRegistry {
    exists: Boolean
    schema_version: Integer
    has_core_group: Boolean
}

-- R-015: Meaningful source identity

entity PrimitiveInstallRecord {
    package_name: String
    package_version: String
    npm_resolved_url: String?
    npm_integrity_hash: String?
    nix_store_path: String?
    settings_hash: String
    manifest_hash: String
    source_hash: String
    installed_at_rfc3339_utc: String
}

surface PrimitiveRegistrySurface {
    facing _: PrimitiveRegistry

    provides:
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: manual)
}

rule PrimitiveRegistryRequiredForSyncPlanning {
    when: SyncRequested(explicit: true, repair_shim: false, _, _)
    ensures: PrimitiveRegistry.exists = true
    ensures: PrimitiveRegistry.schema_version = 1
    ensures: PrimitiveRegistry.has_core_group = true
}

-- R-015: Record exact installed artifact identity

rule PrimitiveInstallMetadataIsRecorded {
    when: SyncCompleted()
    for record in PrimitiveInstallRecord:
        ensures: record.package_name != ""
        ensures: record.package_version != ""
        ensures: record.source_hash != ""
        ensures: record.settings_hash != ""
        ensures: record.manifest_hash != ""
        ensures: record.installed_at_rfc3339_utc != ""
    @guidance
        -- The source_hash must identify the installed artifact, not just
        -- hash the package name string (as the current implementation does).
        -- Record:
        --   exact package name and version from node_modules
        --   npm resolved URL (from npm ls --json)
        --   npm integrity hash (from package-lock.json or npm ls)
        --   Nix store path (if using nix_packaged strategy)
        --   hash of generated settings content
        --   hash of generated manifest content
}

invariant RegistrySchemaIsPinned {
    PrimitiveRegistry.exists implies PrimitiveRegistry.schema_version = 1
}

invariant CoreGroupPresentWhenRegistryExists {
    PrimitiveRegistry.exists implies PrimitiveRegistry.has_core_group
}

invariant SourceIdentityIsMeaningful {
    -- R-015: source_hash must not be a hash of just the package name
    for record in PrimitiveInstallRecord:
        record.package_version != "" and record.settings_hash != ""
}
