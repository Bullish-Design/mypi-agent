-- allium: 3

rule AutoBootstrapOnShellEntry {
    when: ShellEntered()
    requires: not AgentRoot.exists or not AgentRoot.required_dirs_present or not SettingsShim.exists
    ensures: SyncRequested(explicit: false, repair_shim: false)
}

rule SyncBootstrap {
    when: SyncRequested(explicit, repair_shim)
    requires: not AgentRoot.exists or not AgentRoot.required_dirs_present or not SettingsShim.exists
    ensures: AgentRoot.exists = true
    ensures: AgentRoot.required_dirs_present = true
    ensures: SettingsShim.exists = true
    ensures: SyncRun.bootstrap_performed = true
}

rule SyncManifestHeal {
    when: SyncRequested(_, _)
    requires: not InstalledManifest.exists or not InstalledManifest.valid_json
    ensures: InstalledManifest.exists = true
    ensures: InstalledManifest.valid_json = true
    ensures: SyncRun.manifest_healed = true
}

rule SyncShimUpdate {
    when: SyncRequested(explicit: true, repair_shim: false)
    requires: not SettingsShim.locally_modified
    ensures: SettingsShim.points_to_configured_root = true
    ensures: SyncRun.shim_updated = true
}

rule SyncFinalize {
    when: SyncRequested(explicit, repair_shim)
    ensures: SyncRun.explicit = explicit
    ensures: SyncRun.repair_shim = repair_shim
    ensures: SyncRun.existing_files_overwritten = false
    ensures: SyncRun.completed = true
    ensures: SyncCompleted()
}

rule ManualUpgradePosture {
    when: DesiredStateChanged()
    ensures: SyncRun.advisory_shown = true
    ensures: SyncRun.upgrade_requires_explicit_sync = true
}

invariant NoOverwriteByDefault {
    not SyncRun.existing_files_overwritten
}
