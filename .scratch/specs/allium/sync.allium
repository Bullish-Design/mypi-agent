-- allium: 3

-- Core sync workflow specification.
-- R-010: --diff must be read-only.
-- R-011: Settings repair must merge, not overwrite.
-- R-012: Sync must truthfully report overwrites.
-- R-021: Shell bootstrap must not silently swallow failures.
-- R-024: Use atomic writes.
-- P0.3: Bootstrap must not mark completed on failed installs.
-- P0.5: User-owned settings must not be adopted without --repair-shim.
-- P1.1: Generate npmCommand in .pi/settings.json.
-- P1.2: Add sync locking.

use "./core.allium" as core

entity SettingsMergePolicy {
    managed_keys: Set<String>
    marker_key: String
    marker_schema_version: Integer
    user_keys_preserved: Boolean
}

default SettingsMergePolicy merge_policy = {
    -- P1.1: npmCommand added to managed keys
    managed_keys: {"extensions", "skills", "prompts", "themes", "enableSkillCommands", "npmCommand"}
    marker_key: "x-mypi-agent"
    marker_schema_version: 1
}

surface LocalSyncTriggers {
    facing _: AgentRoot

    provides:
        ShellEntered()
        DesiredStateChanged()
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: manual)
        SyncRequested(explicit: true, repair_shim: true, diff_requested: false, trigger: manual)
        SyncRequested(explicit: true, repair_shim: false, diff_requested: true, trigger: manual)
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: shell)
}

-- P1.2: Acquire sync lock before any mutation

rule SyncAcquireLock {
    when: SyncRequested(_, _, diff_requested: false, _)
    ensures: SyncLock.held = true
    @guidance
        -- Create .agents/pi/.state/sync.lock
        -- Use fcntl.flock() on Unix.
        -- Hold the lock across npm install and state writes.
        -- Use unique temp files for JSON writes (NamedTemporaryFile).
}

-- R-010: Diff mode builds plan but does not write

rule SyncDiffMode {
    when: SyncRequested(explicit, repair_shim, diff_requested: true, trigger)
    ensures: SyncRun.diff_requested = true
    ensures: not SyncRun.filesystem_mutated
    ensures: SyncRun.completed = true
    ensures: SyncRun.write_actions.count = 0
    @guidance
        -- Build a sync plan describing what would change.
        -- Print or return the plan.
        -- Exit without any filesystem writes.
        -- Acceptance: hash the project tree before and after; they must match.
}

-- Bootstrap: create missing directories and initial files

rule SyncBootstrap {
    when: SyncRequested(explicit, repair_shim, diff_requested: false, trigger)
    requires: not AgentRoot.exists or not AgentRoot.required_dirs_present or not SettingsShim.exists
    ensures: AgentRoot.exists = true
    ensures: AgentRoot.required_dirs_present = true
    ensures: SettingsShim.exists = true
    ensures: SyncRun.bootstrap_performed = true
    @guidance
        -- Create .agents/pi directory tree.
        -- Create initial .pi/settings.json with managed keys and marker.
        -- Record each write as a WriteAction for truthful reporting.
}

-- Manifest heal: repair or create manifest when invalid

rule SyncManifestHeal {
    when: SyncRequested(_, _, diff_requested: false, _)
    requires: not InstalledManifest.exists or not InstalledManifest.valid_json or not InstalledManifest.schema_valid
    ensures: InstalledManifest.exists = true
    ensures: InstalledManifest.valid_json = true
    ensures: InstalledManifest.schema_valid = true
    ensures: SyncRun.manifest_healed = true
}

-- P0.5: Settings takeover safety.
-- User-owned or invalid settings must not be adopted without --repair-shim.

rule SyncRejectsUserOwnedSettings {
    when: SyncRequested(explicit: true, repair_shim: false, diff_requested: false, _)
    requires: core/SettingsShim.exists and core/SettingsShim.classification in {user_owned, invalid_json}
    ensures: SyncError(reason: "settings_not_mypi_managed")
    @guidance
        -- Print: "error: .pi/settings.json already exists and is not MYPI-managed."
        -- Print: "Run `mypi sync --repair-shim` to adopt/repair the settings shim."
        -- Exit with code 1.
        -- Do not rewrite the settings file.
}

-- R-011: Settings shim update merges managed keys, preserves user keys

rule SyncShimMerge {
    when: SyncRequested(explicit: true, repair_shim: true, diff_requested: false, trigger)
    ensures: core/SettingsShim.points_to_configured_root = true
    ensures: core/SettingsShim.marker_present = true
    ensures: SettingsMergePolicy.user_keys_preserved = true
    ensures: SyncRun.shim_updated = true
    @guidance
        -- Read existing .pi/settings.json if present.
        -- Identify MYPI-managed keys from the marker's managedKeys list.
        -- Update only managed keys with MYPI-generated values.
        -- Preserve all other keys as user-owned.
        -- Write the x-mypi-agent marker with:
        --   managed: true
        --   schemaVersion: 1
        --   agentRoot: relative path to .agents/pi
        --   managedKeys: list of managed key names (includes npmCommand)
        -- Use atomic write (write to temp file, fsync, rename).
}

-- P1.1: Generate npmCommand in settings

rule SyncGeneratesNpmCommand {
    when: SyncRequested(explicit: true, _, diff_requested: false, _)
    ensures: core/SettingsShim.npm_command_configured = true
    @guidance
        -- Generate npmCommand pointing to devenv-provided npm.
        -- Either use the absolute Nix store path to npm:
        --   "npmCommand": ["/nix/store/...-nodejs-22/bin/npm"]
        -- Or generate a small npm wrapper under the agent root:
        --   "npmCommand": ["../.agents/pi/bin/npm"]
        -- Add npmCommand to MANAGED_SETTINGS_KEYS.
}

-- Pi installation via npm

rule SyncInstallPi {
    when: SyncRequested(explicit: true, _, diff_requested: false, _)
    requires: not core/PiExecutable.installed
    requires: core/NodeRuntime.node_available and core/NodeRuntime.npm_available
    ensures: core/PiExecutable.installed = true
    ensures: core/PiExecutable.path_exists = true
    ensures: core/PiExecutable.is_executable = true
    @guidance
        -- Install Pi via npm with pinned version:
        -- npm install --prefix "$MYPI_AGENT_ROOT" \
        --   --ignore-scripts --no-audit --no-fund \
        --   "@earendil-works/pi-coding-agent@<pinned-version>"
        -- Use repo-scoped npm configuration (NPM_CONFIG_PREFIX, NPM_CONFIG_CACHE).
        -- P0.1: After install, verify that node_modules/.bin/pi exists
        -- and is executable. Do NOT generate a wrapper at bin/pi-agent.
}

-- P0.3: Verify pi binary after install, write bootstrap state accordingly.

rule SyncVerifyPiInstalled {
    when: SyncCompleted()
    ensures: if core/PiExecutable.path_exists and core/PiExecutable.is_executable:
        core/BootstrapState.status = completed
        core/BootstrapState.pi_installed = true
        core/BootstrapState.pi_executable = ".agents/pi/node_modules/.bin/pi"
        core/BootstrapState.last_error = null
        core/SyncRun.pi_installed = true
    ensures: if not core/PiExecutable.path_exists or not core/PiExecutable.is_executable:
        core/BootstrapState.status = failed
        core/BootstrapState.pi_installed = false
        core/BootstrapState.last_error = "pi_install_failed"
        core/SyncRun.pi_installed = false
    @guidance
        -- After npm install completes, check:
        -- 1. paths.agent_root / "node_modules" / ".bin" / "pi" exists
        -- 2. os.access(pi_path, os.X_OK) is true
        -- Only then write status = "completed" to bootstrap state.
        -- On failure, write status = "failed" so needs_sync retries.
}

rule SyncRecordsBootstrapState {
    when: SyncCompleted()
    ensures: core/BootstrapState.trigger = core/SyncRun.trigger
    ensures: core/BootstrapState.config_hash = core/DesiredState.config_hash
    ensures: core/BootstrapState.package_name = core/PiPackage.name
    ensures: core/BootstrapState.schema_version = 1
    ensures: if core/PiExecutable.installed:
        core/BootstrapState.package_version = core/PiExecutable.installed_version
}

-- R-012: Finalize with truthful overwrite reporting

rule SyncFinalize {
    when: SyncRequested(explicit, repair_shim, diff_requested: false, trigger)
    ensures: SyncRun.explicit = explicit
    ensures: SyncRun.repair_shim = repair_shim
    ensures: SyncRun.trigger = trigger
    ensures: SyncRun.existing_files_overwritten =
        SyncRun.write_actions.any(a => a.existed_before and a.content_changed)
    ensures: SyncRun.completed = true
    ensures: SyncCompleted()
}

-- R-021: Shell-triggered sync records trigger and surfaces errors

rule ShellBootstrapSync {
    when: ShellEntered()
    requires: core/NeedsSyncResult.sync_needed
    ensures: SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: shell)
    @guidance
        -- In the Nix enterShell hook:
        -- if mypi needs-sync --trigger shell; then
        --   if ! mypi sync --trigger shell; then
        --     echo "warning: mypi bootstrap failed; run: mypi doctor" >&2
        --   fi
        -- fi
        -- Errors are visible. Normal no-op shell entry is quiet.
}

rule ManualUpgradePosture {
    when: DesiredStateChanged()
    ensures: SyncRun.upgrade_requires_explicit_sync = true
}

-- P1.2: Release sync lock after completion

rule SyncReleaseLock {
    when: SyncCompleted()
    ensures: SyncLock.held = false
    @guidance
        -- Release fcntl.flock() after all state writes are done.
        -- Lock is released even on failure (use try/finally).
}

-- R-024: Atomic writes

invariant AtomicWritePolicy {
    for action in SyncRun.write_actions where action.managed:
        AtomicWriteUsed(action.path)
}

invariant NoOverwriteByDefault {
    not SyncRun.existing_files_overwritten
}

invariant SettingsMergePreservesUserKeys {
    -- R-011: user-owned keys are never deleted or modified by sync
    SyncRun.shim_updated implies SettingsMergePolicy.user_keys_preserved
}

-- P0.5: User-owned settings are never silently adopted.

invariant UserOwnedSettingsRequireRepairShim {
    SettingsShim.classification = user_owned and not SyncRun.repair_shim
        implies not SyncRun.shim_updated
}

invariant InvalidJsonSettingsRequireRepairShim {
    SettingsShim.classification = invalid_json and not SyncRun.repair_shim
        implies not SyncRun.shim_updated
}
