-- allium: 3

-- Nix module option set specification.
-- Defines the full piAgent option shape for modules/pi-agent.nix.
-- R-004: nodePackage for npm-capable runtime.
-- R-005: Deterministic Pi installation with version pinning.
-- R-006: Repo-scoped npm configuration.
-- R-018: Remove or implement sourceRoot.
-- R-019: Robust shell quoting.
-- R-020: Consistent Python version pinning.
-- P0.1: Remove expose_pi_agent_shim, expose upstream pi directly.
-- P0.4: Pin piPackageVersion by default for reproducibility.
-- P1.4: Validate piAgent.root rejects absolute paths and traversal.

use "./core.allium" as core

-- The Nix module option set as an entity.
-- Each field corresponds to a lib.mkOption in modules/pi-agent.nix.

entity ModuleOptions {
    enable: Boolean
    root: String
    node_package: String
    pi_package_name: String
    pi_package_version: String?
    npm_install_flags: Set<String>
    bootstrap_mode: first_entry_only | manual_only | every_entry
    allow_floating_pi_version: Boolean
    mypi_agent_version: String
}

default ModuleOptions module_options = {
    enable: true
    root: ".agents/pi"
    node_package: "pkgs.nodejs_22"
    pi_package_name: "@earendil-works/pi-coding-agent"
    pi_package_version: null
    npm_install_flags: {"--ignore-scripts", "--no-audit", "--no-fund"}
    bootstrap_mode: first_entry_only
    allow_floating_pi_version: false
}

-- Environment variables set by the module in the devenv shell.

entity ShellEnvironment {
    mypi_agent_root: String
    mypi_project_root: String
    mypi_agent_version: String
    mypi_pi_package_name: String
    mypi_pi_package_version: String?
    npm_config_prefix: String
    npm_config_cache: String
    npm_config_audit: String
    npm_config_fund: String
    path_includes_node_modules_bin: Boolean
}

surface OptionsLocalTriggers {
    facing _: ShellEnvironment

    provides:
        ShellEntered()
}

-- R-006: npm configuration must be repo-scoped

rule ModuleConfiguresNpmScope {
    when: ShellEntered()
    requires: ModuleOptions.enable
    ensures: ShellEnvironment.mypi_agent_root = ModuleOptions.root
    ensures: ShellEnvironment.npm_config_prefix = ModuleOptions.root + "/npm-global"
    ensures: ShellEnvironment.npm_config_cache = ModuleOptions.root + "/.npm-cache"
    ensures: ShellEnvironment.npm_config_audit = "false"
    ensures: ShellEnvironment.npm_config_fund = "false"
    ensures: NpmScope.prefix_is_project_local = true
    ensures: NpmScope.cache_is_project_local = true
    ensures: NpmScope.audit_disabled = true
    ensures: NpmScope.fund_disabled = true
}

-- R-004: Module provides node and npm on PATH

rule ModuleProvidesNodeRuntime {
    when: ShellEntered()
    requires: ModuleOptions.enable
    ensures: NodeRuntime.node_available = true
    ensures: NodeRuntime.npm_available = true
    ensures: NodeRuntime.npx_available = true
    @guidance
        -- The module adds cfg.nodePackage to the shell packages list.
        -- This provides node, npm, and npx on PATH.
        -- Recommended Nix shape:
        -- packages = [ mypiBin cfg.nodePackage ];
}

-- P0.1: Expose upstream pi directly via PATH, not through a wrapper.

rule ModuleExposesUpstreamPi {
    when: ShellEntered()
    requires: ModuleOptions.enable
    ensures: ConsumerProject.has_mypi_on_path = true
    ensures: ShellEnvironment.path_includes_node_modules_bin = true
    @guidance
        -- Add the project-local npm bin directory to PATH during shell entry:
        -- enterShell = lib.mkAfter ''
        --   project_root="''${DEVENV_ROOT:-$PWD}"
        --   export PATH="$project_root/$root_rel/node_modules/.bin:$PATH"
        -- '';
        -- This exposes the upstream pi binary directly. No pi-agent wrapper.
        -- The pi command resolves to .agents/pi/node_modules/.bin/pi.
}

-- P0.1: Export MYPI_AGENT_VERSION for config hash computation.

rule ModuleExportsVersion {
    when: ShellEntered()
    requires: ModuleOptions.enable
    ensures: ShellEnvironment.mypi_agent_version = ModuleOptions.mypi_agent_version
    @guidance
        -- Export MYPI_AGENT_VERSION from the Nix package version.
        -- The Python config hash includes this value.
}

-- P1.4: Validate piAgent.root rejects absolute paths and ".." traversal.

invariant RootIsProjectRelative {
    ModuleOptions.enable implies
        not ModuleOptions.root.starts_with("/")
        and not ModuleOptions.root.contains("..")
}

-- R-019: Shell quoting must be robust

invariant ShellQuotingIsRobust {
    -- All cfg values interpolated into shell scripts must use lib.escapeShellArg.
    -- The root must be validated as project-relative.
    ModuleOptions.enable implies
        ShellEnvironment.mypi_agent_root = ModuleOptions.root
}

-- P0.4: Reproducibility - pinned version by default.

invariant PinnedVersionByDefault {
    -- If piPackageVersion is null and allow_floating_pi_version is false,
    -- sync must error or warn. Floating versions require explicit opt-in.
    ModuleOptions.pi_package_version = null and not ModuleOptions.allow_floating_pi_version
        implies PiPackage.install_strategy != floating_npm
}

-- R-018: sourceRoot must be removed

open question "sourceRoot has been removed as R-018 requires. If a concrete override behavior is needed later, it should be added with actual effect on package/module source selection."

-- R-020: Python version consistency

open question "pyproject.toml requires >=3.13 but packages/mypi-agent-cli.nix uses generic python3Packages. The Nix package should use python313Packages or a configurable Python package set."
