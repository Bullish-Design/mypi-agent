-- allium: 3

entity UseTopologyPolicy {
    topology_enforcement_descope_active: Boolean
}

surface LocalTopologyTriggers {
    facing _: UseTopologyPolicy

    provides:
        ShellEntered()
}

rule RecordTopologyDescopeDecision {
    when: ShellEntered()
    ensures: UseTopologyPolicy.topology_enforcement_descope_active = true
}

invariant TopologyPolicyExplicitlyDescoped {
    UseTopologyPolicy.topology_enforcement_descope_active
}
