-- allium: 3

surface LocalSecretsTriggers {
    facing _: SecretRuntimePolicy

    provides:
        MypiInvoked()
}

rule RuntimeSecretsOnly {
    when: MypiInvoked()
    ensures: SecretRuntimePolicy.runtime_env_load_attempted = true
    ensures: SecretRuntimePolicy.config_write_attempted = false
    ensures: SecretRuntimePolicy.config_write_blocked = true
    ensures: SecretRuntimePolicy.secrets_written_to_generated_config = false
    ensures: SecretRuntimePolicy.secrets_available_at_evaluation_time = false
    ensures: RuntimeEnvLoadAttempted()
}

rule RuntimeEnvLoadCompletes {
    when: RuntimeEnvLoadAttempted()
    ensures: SecretRuntimePolicy.runtime_env_load_completed = true
    ensures: SecretRuntimePolicy.missing_env_files_warning = true
    ensures: SecretRuntimePolicy.warning_reason_missing_env_files_only = true
}
