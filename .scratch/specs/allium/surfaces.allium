-- allium: 3

-- All user-facing command surfaces for mypi CLI.
-- R-008: All user-facing operations go through mypi.
-- R-009: mypi run must either run something or be removed.
-- R-013: Content-aware settings shim classification.
-- R-022: mypi needs-sync lightweight check.
-- P0.1: Upstream pi is exposed directly, not through a wrapper.
-- P0.2: mypi pi must pass through all upstream flags.
-- P0.6: needs-sync must verify actual runtime state.

use "./core.allium" as core

entity SettingsShim {
    exists: Boolean
    classification: missing | managed_unchanged | managed_changed | user_owned | user_modified | invalid_json
    points_to_configured_root: Boolean
    managed_keys: List<String>
    marker_present: Boolean
    marker_schema_version: Integer when marker_present
    npm_command_configured: Boolean
}

-- Shell entry surface

surface ShellEntrySurface {
    facing _: SettingsShim

    provides:
        ShellEntered()
        DesiredStateChanged()

    @guarantee VisibleBootstrap
        -- R-021: Shell bootstrap must not silently swallow failures.
        -- Errors are visible. Normal no-op shell entry is quiet.
        -- Bootstrap does not repeatedly perform expensive network installs.

    @guarantee DirectPiExposure
        -- P0.1: The shell adds .agents/pi/node_modules/.bin to PATH,
        -- exposing the upstream pi binary directly. No pi-agent wrapper
        -- is generated or required for the default path.
}

-- Main mypi command surface

surface MypiCommand {
    facing _: SettingsShim

    provides:
        MypiInvoked()

    exposes:
        SecretRuntimePolicy.runtime_env_load_attempted
        SecretRuntimePolicy.runtime_env_load_completed
        SecretRuntimePolicy.config_write_attempted
        SecretRuntimePolicy.config_write_blocked
        SecretRuntimePolicy.secrets_available_at_evaluation_time
        SecretRuntimePolicy.secrets_written_to_generated_config
        SecretRuntimePolicy.missing_env_files_warning
        SecretRuntimePolicy.warning_reason_missing_env_files_only
}

-- P0.1/P0.2: mypi pi command - passthrough to upstream Pi CLI.
-- Replaces the old AgentCommandSurface. The upstream CLI is "pi",
-- not "pi-agent". mypi pi is an optional passthrough alias.

surface PiCommandSurface {
    facing _: core/PiExecutable

    provides:
        PiRequested(args: List<String>)

    exposes:
        core/PiExecutable.installed
        core/PiExecutable.path_exists
        core/PiExecutable.is_executable
        core/PiExecutable.version_check_passed

    @guarantee PiPassthrough
        -- P0.2: mypi pi forwards ALL arguments to the upstream Pi executable,
        -- including unknown flags like --version, --mode rpc, -p "prompt".
        -- Uses Typer context_settings with allow_extra_args and
        -- ignore_unknown_options. Exit code is preserved from the Pi process.
        -- If Pi is not installed, emits a clear error directing
        -- the user to run mypi sync.
}

rule PiLaunchesPi {
    when: PiRequested(args)
    requires: core/PiExecutable.path_exists and core/PiExecutable.is_executable
    ensures: PiLaunched(args)
    @guidance
        -- Execute the upstream Pi binary at node_modules/.bin/pi,
        -- forwarding all args via ctx.args.
        -- Preserve stdin/stdout/stderr and exit code.
        -- Implementation:
        -- @app.command("pi", context_settings={"allow_extra_args": True, "ignore_unknown_options": True})
        -- def pi_command(ctx: typer.Context) -> None:
        --     result = subprocess.run([str(pi_executable), *ctx.args], check=False)
        --     raise typer.Exit(code=result.returncode)
}

rule PiFailsWhenPiMissing {
    when: PiRequested(args)
    requires: not core/PiExecutable.path_exists or not core/PiExecutable.is_executable
    ensures: PiError(reason: "pi_not_available")
    @guidance
        -- Print: "error: Pi is not installed. Run: mypi sync"
        -- Exit with code 1.
}

-- Sync command surface

surface SyncCommandSurface {
    facing _: SettingsShim

    provides:
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: manual)
        SyncRequested(explicit: true, repair_shim: true, diff_requested: false, trigger: manual)
        SyncRequested(explicit: true, repair_shim: false, diff_requested: true, trigger: manual)
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: shell)

    exposes:
        SettingsShim.classification
        SyncRun.explicit
        SyncRun.repair_shim
        SyncRun.diff_requested
        SyncRun.trigger
        SyncRun.completed
        SyncRun.pi_installed
        SyncRun.existing_files_overwritten
        SyncRun.bootstrap_performed
        SyncRun.manifest_healed
        SyncRun.shim_updated
        SyncRun.advisory_shown
        SyncRun.upgrade_requires_explicit_sync
        SyncRun.write_actions
        InstalledManifest.exists
        InstalledManifest.valid_json
        InstalledManifest.schema_valid
        SettingsShim.points_to_configured_root
        BootstrapState.status
        BootstrapState.pi_installed

    @guarantee NonDestructiveDefault
        -- Explicit sync creates missing files and does not overwrite existing files by default.

    @guarantee DiffIsReadOnly
        -- R-010: When --diff is set, the sync plan is printed and no filesystem writes occur.

    @guarantee SettingsSafety
        -- P0.5: Sync will not silently adopt user-owned or invalid .pi/settings.json.
        -- Requires --repair-shim to adopt/repair non-MYPI-managed settings.
}

-- R-022: mypi needs-sync lightweight check
-- P0.6: needs-sync must verify actual runtime state, not just config hash.

surface NeedsSyncSurface {
    facing _: SettingsShim

    provides:
        NeedsSyncRequested(trigger: shell | manual)

    exposes:
        NeedsSyncResult.sync_needed
        NeedsSyncResult.reason

    @guarantee Lightweight
        -- needs-sync compares a config hash/state file rather than
        -- performing full sync planning. It does not mutate the filesystem.

    @guarantee RuntimeStateAware
        -- P0.6: needs-sync checks actual runtime invariants, not just
        -- config hash. A missing or non-executable pi binary, failed
        -- bootstrap status, or missing resource dirs all trigger sync.
}

entity NeedsSyncResult {
    sync_needed: Boolean
    reason: String when sync_needed
}

-- P0.6: Deepened needs-sync check that verifies actual runtime state.

rule NeedsSyncChecksRuntimeState {
    when: NeedsSyncRequested(trigger)
    ensures: NeedsSyncResult.sync_needed =
        not AgentRoot.exists
        or not SettingsShim.exists
        or not InstalledManifest.exists
        or not PiExecutable.path_exists
        or not PiExecutable.is_executable
        or BootstrapState.status != completed
        or core/DesiredState.hash_inputs_changed
    ensures: if NeedsSyncResult.sync_needed:
        NeedsSyncResult.reason = "state_drift_detected"
    @guidance
        -- P0.6: Minimum checks beyond config hash:
        -- 1. pi binary exists at node_modules/.bin/pi
        -- 2. pi binary is executable
        -- 3. bootstrap state status is "completed"
        -- 4. resource directories exist
        -- Better: also validate manifest schema, installed package
        -- version against MYPI_PI_PACKAGE_VERSION, npm package metadata.
        -- Hash inputs include: piAgent.root, Pi package name/version,
        -- npm install flags, managed settings schema version,
        -- managed resources manifest schema version, mypi-agent version.
}

-- Doctor command surface

surface DoctorCommandSurface {
    facing _: SettingsShim

    provides:
        DoctorRequested()

    exposes:
        DoctorRun.requested
        DoctorRun.checks_completed
        DoctorRun.error_count
        DoctorRun.warning_count
        DoctorRun.exit_code

    @guarantee RunsWhenBroken
        -- P0.2 (cli review): Doctor should run even when the settings shim
        -- is missing or invalid. Doctor diagnoses broken bootstrap states,
        -- it should not be blocked by them.
}

-- Paths command surface

surface PathsCommandSurface {
    facing _: SettingsShim

    provides:
        PathsRequested()

    exposes:
        PathsSurface.command_available
        PathsSurface.project_root_exposed
        PathsSurface.shim_path_exposed
        PathsSurface.agent_root_exposed
        PathsSurface.manifest_path_exposed
        PathsSurface.pi_executable_path_exposed
        PathsSurface.node_path_exposed
        PathsSurface.npm_prefix_exposed
}
