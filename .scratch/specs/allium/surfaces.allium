-- allium: 3

-- User-facing command surfaces for mypi CLI and the pi wrapper.
-- R-008: All setup/validation operations go through mypi.
-- R-013: Content-aware settings shim classification.
-- R-022: mypi needs-sync lightweight check.
-- P0.6: needs-sync must verify actual runtime state.
-- Pi is accessed via scripts.pi wrapper with SecretSpec injection.

use "./core.allium" as core

entity SettingsShim {
    exists: Boolean
    classification: missing | managed_unchanged | managed_changed | user_owned | user_modified | invalid_json
    points_to_configured_root: Boolean
    managed_keys: List<String>
    marker_present: Boolean
    marker_schema_version: Integer when marker_present
    npm_command_configured: Boolean
}

-- Shell entry surface

surface ShellEntrySurface {
    facing _: SettingsShim

    provides:
        ShellEntered()
        DesiredStateChanged()

    @guarantee ErrorVisibility
        -- R-021: Bootstrap errors are visible. No silent failures.

    @guarantee PiViaWrapper
        -- Pi is accessed via scripts.pi wrapper, not raw PATH.
        -- node_modules/.bin is not on PATH.
}

-- Main mypi command surface

surface MypiCommand {
    facing _: SettingsShim

    provides:
        MypiInvoked()
}

-- Pi wrapper surface (Nix scripts.pi, not a Python CLI command).
-- The wrapper calls the real Pi binary by absolute path through
-- `secretspec run`, injecting API keys into the Pi process only.

surface PiWrapperSurface {
    facing _: core/PiExecutable

    provides:
        PiRequested(args: List<String>)

    @guarantee SecretSpecInjection
        -- Pi receives API keys via `secretspec run -- <real_pi>`.
        -- Keys exist only in the Pi process environment, not the shell.

    @guarantee AbsolutePathResolution
        -- The wrapper calls Pi by absolute path at
        -- $project_root/$agent_root/node_modules/.bin/pi.
        -- node_modules/.bin is never on PATH.

    @guarantee ArgsPassthrough
        -- All arguments forwarded unchanged, preserving exit code.
}

rule PiWrapperLaunchesPi {
    when: PiRequested(args)
    requires: core/PiExecutable.path_exists and core/PiExecutable.is_executable
    ensures: PiLaunched(args)
    @guidance
        -- Implemented as a Nix scripts.pi wrapper (not Python CLI).
        -- exec secretspec run [--provider P] [--profile P] -- "$real_pi" "$@"
}

rule PiWrapperFailsWhenPiMissing {
    when: PiRequested(args)
    requires: not core/PiExecutable.path_exists or not core/PiExecutable.is_executable
    ensures: PiError(reason: "pi_not_available")
    @guidance
        -- Print: "error: Pi is not installed. Run: mypi sync"
        -- Exit with code 127.
}

-- Sync command surface

surface SyncCommandSurface {
    facing _: SettingsShim

    provides:
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: manual)
        SyncRequested(explicit: true, repair_shim: true, diff_requested: false, trigger: manual)
        SyncRequested(explicit: true, repair_shim: false, diff_requested: true, trigger: manual)
        SyncRequested(explicit: true, repair_shim: false, diff_requested: false, trigger: shell)

    @guarantee NonDestructiveDefault
        -- Creates missing files, does not overwrite existing files by default

    @guarantee DiffIsReadOnly
        -- R-010: --diff mode prints plan without writing filesystem

    @guarantee SettingsSafety
        -- P0.5: User-owned settings require --repair-shim flag
}

-- R-022: mypi needs-sync lightweight check
-- P0.6: needs-sync must verify actual runtime state, not just config hash.

surface NeedsSyncSurface {
    facing _: SettingsShim

    provides:
        NeedsSyncRequested(trigger: shell | manual)

    @guarantee Lightweight
        -- Fast check without full sync planning

    @guarantee RuntimeStateAware
        -- P0.6: Checks actual runtime state, not just config hash
}

entity NeedsSyncResult {
    sync_needed: Boolean
    reason: String when sync_needed
}

-- P0.6: Deepened needs-sync check that verifies actual runtime state.

rule NeedsSyncChecksRuntimeState {
    when: NeedsSyncRequested(trigger)
    ensures: NeedsSyncResult.sync_needed =
        not AgentRoot.exists
        or not SettingsShim.exists
        or not InstalledManifest.exists
        or not PiExecutable.path_exists
        or not PiExecutable.is_executable
        or BootstrapState.status != completed
        or core/DesiredState.hash_inputs_changed
    ensures: if NeedsSyncResult.sync_needed:
        NeedsSyncResult.reason = "state_drift_detected"
    @guidance
        -- P0.6: Minimum checks beyond config hash:
        -- 1. pi binary exists at node_modules/.bin/pi
        -- 2. pi binary is executable
        -- 3. bootstrap state status is "completed"
        -- 4. resource directories exist
        -- Better: also validate manifest schema, installed package
        -- version against MYPI_PI_PACKAGE_VERSION, npm package metadata.
        -- Hash inputs include: piAgent.root, Pi package name/version,
        -- npm install flags, managed settings schema version,
        -- managed resources manifest schema version, mypi-agent version.
}

-- Pi profile surface
-- `devenv -P pi shell` launches pi on entry, then drops to interactive shell.

surface PiProfileSurface {
    facing _: core/PiExecutable

    provides:
        PiProfileEntered()

    @guarantee InteractiveAfterExit
        -- Pi is launched without exec, so the shell remains interactive
        -- after pi exits (Ctrl+C or /exit).

    @guarantee NoEffectOnDefaultShell
        -- The default `devenv shell` (no -P flag) is unaffected.
}

-- Doctor command surface

surface DoctorCommandSurface {
    facing _: SettingsShim

    provides:
        DoctorRequested()

    @guarantee RunsWhenBroken
        -- Diagnoses broken states; not blocked by bootstrap failures
}

-- Paths command surface

surface PathsCommandSurface {
    facing _: SettingsShim

    provides:
        PathsRequested()
}
